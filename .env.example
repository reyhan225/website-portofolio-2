# Environment template for Vercel / local development
# Rename to .env.local for Vercel UI import or source locally

NODE_ENV=production

# Firebase service account JSON as one line (paste entire JSON)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"<your-project-id>","private_key_id":"<...>","private_key":"-----BEGIN PRIVATE KEY-----\\n<key>\\n-----END PRIVATE KEY-----\\n","client_email":"<firebase-adminsdk@project.iam.gserviceaccount.com>","client_id":"<id>","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk"}

# Admin auth
ADMIN_PASSWORD=change-me
ADMIN_JWT_SECRET=long-random-secret
ADMIN_EMAIL=reyhanmuhamadrizki1@gmail.com
ADMIN_TOKEN_TTL_SEC=3600
ADMIN_BASE_PATH=/secure-admin-2026

# CORS allowed origins (CSV)
CORS_ORIGINS=https://reyhan-muhamad-rizki.vercel.app,https://admin-reyhan-muhamad-rizki.vercel.app

# Optional hardening
ADMIN_ALLOWED_IPS=
ADMIN_LOGIN_WINDOW_MIN=15
ADMIN_LOGIN_MAX_FAILURES=6
ADMIN_LOGIN_BLOCK_MIN=30

# Resume link (optional override)
CV_URL=https://reyhan-muhamad-rizki.vercel.app/cv.pdf
CV_UPDATED_AT=2025-01-01T00:00:00.000Z
